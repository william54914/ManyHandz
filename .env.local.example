# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=a_random_secret_for_cron_endpoints
# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_ANNUAL=price_...
# WebAuthn / Passkeys
WEBAUTHN_RP_NAME=ManyHandz
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000
# Web Push (VAPID keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
# Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@manyhandz.com
SUPPORT_EMAIL=support@manyhandz.com
# AI
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
AI_VERIFICATION_PROVIDER=openai
AI_VERIFICATION_MODEL=gpt-4o
AI_AUTO_APPROVE_THRESHOLD=85
AI_AUTO_REJECT_THRESHOLD=40
AI_VERIFICATION_ENABLED=true
